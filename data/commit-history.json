  "freeappstore-online/meetup": {
    "meta": {
      "created_at": "2026-05-04T01:43:06Z",
      "pushed_at": "2026-05-04T09:52:41Z"
    },
    "commits": [
      {
        "sha": "02ab496a302f16e0e2dd5452c334e3edfa3de932",
        "html_url": "https://github.com/freeappstore-online/meetup/commit/02ab496a302f16e0e2dd5452c334e3edfa3de932",
        "commit": {
          "message": "Fix: vendor SDK into repo so CF Pages builds succeed\n\nSDK was a workspace link to a directory outside the repo — CF Pages\ncan't resolve it during build. Moved SDK source into web/src/sdk/\nwith direct relative imports. Two prior deploys were failing for this.\n\nCo-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>",
          "author": {
            "date": "2026-05-04T09:52:39Z"
          }
        }
      },
      {
        "sha": "7b34fa295b2c412f391bc661f086b381d68818f4",
        "html_url": "https://github.com/freeappstore-online/meetup/commit/7b34fa295b2c412f391bc661f086b381d68818f4",
        "commit": {
          "message": "Fix: remove dead Firebase, wire RSVP to API, fix SPA routing\n\n- Remove firebase dependency and lib/firebase.ts (dead code)\n- RSVP button now calls platform API (POST/DELETE /meetup/events/:id/rsvp)\n- Add _redirects for CF Pages SPA routing (fixes 404 on direct links)\n- Fix useAuth to use UserWithRoles type from SDK\n\nCo-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>",
          "author": {
            "date": "2026-05-04T09:13:49Z"
          }
        }
      },
      {
        "sha": "176be3e60ef952f2b1c123a78dd237d222595607",
        "html_url": "https://github.com/freeappstore-online/meetup/commit/176be3e60ef952f2b1c123a78dd237d222595607",
        "commit": {
          "message": "Switch meetup from Firebase to FreeAppStore platform API\n\nUses @freeappstore/sdk to talk to api.freeappstore.online (CF Workers + D1).\nFirebase completely removed — bundle dropped from 622KB to 428KB.\nEvents now served from D1 with local seed data as fallback.\n\nCo-Authored-By: Claude Opus 4.6 (1M context) <noreply@anthropic.com>",
          "author": {
            "date": "2026-05-04T08:51:15Z"
          }
        }
      }
    ]
  },
